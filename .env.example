TELEGRAM_BOT_TOKEN=COLE_AQUI_O_TOKEN_DO_BOTFATHER

# Opcional
TELEGRAM_MAX_FILE_MB=20
TELEGRAM_TIMEOUT_SECONDS=180
OUTPUT_FORMAT=eps
VECTORIZATION_PROVIDER=vectorizer_ai

# Vectorizer.AI por automacao de navegador
VECTORIZER_AI_URL=https://pt.vectorizer.ai/
VECTORIZER_AI_HEADLESS=false
VECTORIZER_AI_PROFILE_DIR=.vectorizer-ai-profile
VECTORIZER_AI_TIMEOUT_SECONDS=300
VECTORIZER_AI_LOGIN_SECONDS=300
VECTORIZER_AI_INPUT_MAX_PIXELS=3000000
VECTORIZER_AI_OFFSCREEN_PROCESSING=false
VECTORIZER_AI_FINAL_DOWNLOAD_DELAY_SECONDS=0
VECTORIZER_AI_DIRECT_DOWNLOAD_TIMEOUT_SECONDS=90
PLAYWRIGHT_AUTO_INSTALL=true
VECTORIZER_AI_COOKIE_NAME=VK
VECTORIZER_AI_COOKIE_VALUE=
VECTORIZER_AI_COOKIE_DOMAIN=.vectorizer.ai
# Opcional: cole varios cookies no formato "VK=valor; atk=valor"
VECTORIZER_AI_COOKIE_HEADER=
# Opcional: JSON exportado pelo Playwright com todos os cookies do Vectorizer.AI
VECTORIZER_AI_COOKIES_JSON=
# Opcional: caminho para arquivo JSON local com cookies exportados
VECTORIZER_AI_COOKIES_FILE=

# Ajustes locais do VTracer
VTRACER_INPUT_MAX_PIXELS=6000000
VTRACER_COLORMODE=color
VTRACER_HIERARCHICAL=stacked
VTRACER_MODE=spline
VTRACER_FILTER_SPECKLE=4
VTRACER_COLOR_PRECISION=6
VTRACER_LAYER_DIFFERENCE=16
VTRACER_CORNER_THRESHOLD=60
VTRACER_LENGTH_THRESHOLD=4.0
VTRACER_MAX_ITERATIONS=10
VTRACER_SPLICE_THRESHOLD=45
VTRACER_PATH_PRECISION=3
